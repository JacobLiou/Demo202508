<Application x:Class="MarkWithVibe.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MarkWithVibe"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- VS Code-like dark theme -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#252526"/>
        <SolidColorBrush x:Key="PreviewBackgroundBrush" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#252526"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#d4d4d4"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#858585"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#3c3c3c"/>

        <!-- Default style for Window to avoid white flash -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
        </Style>
    </Application.Resources>
</Application>
