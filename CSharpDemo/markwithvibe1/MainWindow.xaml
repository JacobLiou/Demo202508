<Window x:Class="MarkWithVibe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:MarkWithVibe"
        mc:Ignorable="d"
        Title="Mark With Vibe - Markdown Editor"
        Height="600" Width="1000"
        MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="8,6" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource ToolbarBackgroundBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Mark With Vibe" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                <Separator Margin="12,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                <TextBlock Text="左侧编辑 · 右侧实时预览" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Editor + Preview split -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Markdown Editor -->
            <Border Grid.Column="0" Margin="0" Padding="12,8" Background="{DynamicResource EditorBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="编辑区" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="EditorBox" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="14"
                             Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}"
                             CaretBrush="{DynamicResource PrimaryTextBrush}"
                             BorderThickness="0"
                             VerticalContentAlignment="Top"
                             TextChanged="EditorBox_TextChanged"/>
                </Grid>
            </Border>

            <!-- Resizable splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderSubtleBrush}"
                          ShowsPreview="False"/>

            <!-- Right: Live Preview (WebView2) -->
            <Border Grid.Column="2" Margin="0" Padding="12,8" Background="{DynamicResource PreviewBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="预览" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,6"/>
                    <wv2:WebView2 x:Name="PreviewWebView" Grid.Row="1"
                                  DefaultBackgroundColor="Transparent"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
