<Window x:Class="MarkdownEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Markdown Editor" 
        Height="700" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+B" Command="{Binding InsertBoldCommand}"/>
        <KeyBinding Gesture="Ctrl+I" Command="{Binding InsertItalicCommand}"/>
        <KeyBinding Gesture="Ctrl+K" Command="{Binding InsertLinkCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+K" Command="{Binding InsertCodeCommand}"/>
        <KeyBinding Gesture="Ctrl+1" Command="{Binding InsertHeading1Command}"/>
        <KeyBinding Gesture="Ctrl+2" Command="{Binding InsertHeading2Command}"/>
        <KeyBinding Gesture="Ctrl+3" Command="{Binding InsertHeading3Command}"/>
    </Window.InputBindings>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 菜单栏 -->
        <Menu Grid.Row="0" Background="{DynamicResource MenuBackgroundBrush}" 
              Foreground="{DynamicResource ForegroundBrush}">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建(_N)" Command="{Binding NewCommand}" InputGestureText="Ctrl+N">
                    <MenuItem.Icon>
                        <TextBlock Text="📄" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="打开(_O)" Command="{Binding OpenCommand}" InputGestureText="Ctrl+O">
                    <MenuItem.Icon>
                        <TextBlock Text="📂" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="保存(_S)" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <TextBlock Text="💾" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="另存为(_A)" Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="导出HTML" Command="{Binding ExportHtmlCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="🌐" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="退出(_X)" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="编辑(_E)">
                <MenuItem Header="撤销" Command="ApplicationCommands.Undo" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="重做" Command="ApplicationCommands.Redo" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="剪切" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X"/>
                <MenuItem Header="复制" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"/>
                <MenuItem Header="粘贴" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V"/>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="仅编辑器" Command="{Binding ViewEditorOnlyCommand}" 
                          IsChecked="{Binding IsEditorOnlyView, Mode=OneWay}">
                    <MenuItem.Icon>
                        <TextBlock Text="📝" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="仅预览" Command="{Binding ViewPreviewOnlyCommand}"
                          IsChecked="{Binding IsPreviewOnlyView, Mode=OneWay}">
                    <MenuItem.Icon>
                        <TextBlock Text="👁️" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="分栏视图" Command="{Binding ViewSplitCommand}"
                          IsChecked="{Binding IsSplitView, Mode=OneWay}">
                    <MenuItem.Icon>
                        <TextBlock Text="◫" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="主题">
                    <MenuItem.Icon>
                        <TextBlock Text="🎨" FontSize="14"/>
                    </MenuItem.Icon>
                    <MenuItem Header="深色主题" Command="{Binding SwitchToDarkThemeCommand}" 
                              IsChecked="{Binding IsDarkTheme, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock Text="🌙" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="浅色主题" Command="{Binding SwitchToLightThemeCommand}"
                              IsChecked="{Binding IsLightTheme, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock Text="☀️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="Markdown语法帮助" Command="{Binding MarkdownHelpCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="❓" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="关于" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>
        
        <!-- 工具栏 -->
        <Border Grid.Row="1" Background="{DynamicResource ToolbarBackgroundBrush}" 
                Padding="8,4" BorderThickness="0,0,0,1" 
                BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding NewCommand}" 
                        ToolTip="新建 (Ctrl+N)">
                    <TextBlock Text="📄" FontSize="16"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding OpenCommand}" 
                        ToolTip="打开 (Ctrl+O)">
                    <TextBlock Text="📂" FontSize="16"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding SaveCommand}" 
                        ToolTip="保存 (Ctrl+S)">
                    <TextBlock Text="💾" FontSize="16"/>
                </Button>
                
                <Separator Style="{DynamicResource ToolbarSeparator}"/>
                
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertBoldCommand}" 
                        ToolTip="粗体 (Ctrl+B)">
                    <TextBlock Text="B" FontWeight="Bold" FontSize="14"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertItalicCommand}" 
                        ToolTip="斜体 (Ctrl+I)">
                    <TextBlock Text="I" FontStyle="Italic" FontSize="14"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertStrikethroughCommand}" 
                        ToolTip="删除线">
                    <TextBlock Text="S" TextDecorations="Strikethrough" FontSize="14"/>
                </Button>
                
                <Separator Style="{DynamicResource ToolbarSeparator}"/>
                
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertHeading1Command}" 
                        ToolTip="一级标题">
                    <TextBlock Text="H1" FontWeight="Bold" FontSize="12"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertHeading2Command}" 
                        ToolTip="二级标题">
                    <TextBlock Text="H2" FontWeight="Bold" FontSize="12"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertHeading3Command}" 
                        ToolTip="三级标题">
                    <TextBlock Text="H3" FontWeight="Bold" FontSize="12"/>
                </Button>
                
                <Separator Style="{DynamicResource ToolbarSeparator}"/>
                
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertLinkCommand}" 
                        ToolTip="插入链接">
                    <TextBlock Text="🔗" FontSize="16"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertImageCommand}" 
                        ToolTip="插入图片">
                    <TextBlock Text="🖼️" FontSize="16"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertCodeCommand}" 
                        ToolTip="代码块">
                    <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" FontSize="12"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertQuoteCommand}" 
                        ToolTip="引用">
                    <TextBlock Text="❝" FontSize="16"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertListCommand}" 
                        ToolTip="列表">
                    <TextBlock Text="☰" FontSize="16"/>
                </Button>
                <Button Style="{DynamicResource ToolbarButton}" Command="{Binding InsertTableCommand}" 
                        ToolTip="表格">
                    <TextBlock Text="▦" FontSize="16"/>
                </Button>
            </StackPanel>
        </Border>
        
        <!-- 主编辑区域 -->
        <Grid Grid.Row="2" x:Name="MainContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" x:Name="EditorColumn" MinWidth="200"/>
                <ColumnDefinition Width="5" x:Name="SplitterColumn"/>
                <ColumnDefinition Width="*" x:Name="PreviewColumn" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧编辑器 -->
            <Border Grid.Column="0" x:Name="EditorPanel" BorderThickness="0,0,1,0" 
                    BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 编辑器标题栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource TabBackgroundBrush}" 
                            Padding="12,8" BorderThickness="0,0,0,1" 
                            BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="编辑" FontWeight="SemiBold" 
                                     Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text=" - " Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            <TextBlock Text="{Binding FileName}" 
                                     Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            <TextBlock Text="*" Foreground="{DynamicResource AccentBrush}"
                                     Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 编辑器 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 行号 -->
                        <Border Grid.Column="0" Background="{DynamicResource LineNumberBackgroundBrush}" 
                                Padding="8,0">
                            <TextBlock x:Name="LineNumbers" 
                                     FontFamily="Cascadia Code, Consolas, Courier New"
                                     FontSize="13" 
                                     Foreground="{DynamicResource LineNumberForegroundBrush}"
                                     TextAlignment="Right"
                                     Padding="0,4"/>
                        </Border>
                        
                        <!-- 文本编辑器 -->
                        <TextBox Grid.Column="1" x:Name="Editor"
                               Text="{Binding MarkdownContent, UpdateSourceTrigger=PropertyChanged}"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="14"
                               AcceptsReturn="True"
                               AcceptsTab="True"
                               TextWrapping="Wrap"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Disabled"
                               Background="{DynamicResource EditorBackgroundBrush}"
                               Foreground="{DynamicResource EditorForegroundBrush}"
                               CaretBrush="{DynamicResource AccentBrush}"
                               BorderThickness="0"
                               Padding="8,4"
                               TextChanged="Editor_TextChanged"
                               SelectionChanged="Editor_SelectionChanged"/>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" x:Name="SplitterGrid"
                         Width="5" 
                         HorizontalAlignment="Stretch"
                         Background="{DynamicResource SplitterBrush}"
                         Cursor="SizeWE"/>
            
            <!-- 右侧预览 -->
            <Border Grid.Column="2" x:Name="PreviewPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 预览标题栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource TabBackgroundBrush}" 
                            Padding="12,8" BorderThickness="0,0,0,1" 
                            BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁️" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="预览" FontWeight="SemiBold" 
                                     Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- WebView2 预览 -->
                    <wv2:WebView2 Grid.Row="1" x:Name="Preview" 
                                 DefaultBackgroundColor="Transparent"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="{DynamicResource StatusBarBackgroundBrush}" 
                Padding="12,6" BorderThickness="0,1,0,0" 
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                         Foreground="{DynamicResource SecondaryForegroundBrush}"
                         VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" 
                         Text="{Binding CursorPosition, StringFormat='行 {0}'}" 
                         Foreground="{DynamicResource SecondaryForegroundBrush}"
                         Margin="16,0" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="2" 
                         Text="{Binding WordCount, StringFormat='字数: {0}'}" 
                         Foreground="{DynamicResource SecondaryForegroundBrush}"
                         Margin="16,0" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="3" Text="UTF-8" 
                         Foreground="{DynamicResource SecondaryForegroundBrush}"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
